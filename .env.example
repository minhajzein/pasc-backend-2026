# ---------------------------------------------------------------------------
# SMTP – required for sending OTP emails on team registration
# ---------------------------------------------------------------------------
# Gmail (recommended):
#   1. Use a Google account (e.g. pasfiesta@gmail.com).
#   2. Enable 2-Step Verification: Google Account → Security → 2-Step Verification.
#   3. Create an App Password: Google Account → Security → App passwords →
#      generate a 16-character password for "Mail" / "Other".
#   4. Set SMTP_USER to the Gmail address and SMTP_PASS to the app password.
#   Do NOT use your normal Gmail password.
#
# Other providers: set host/port/secure as per their docs (e.g. Outlook, Yahoo).
# ---------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
