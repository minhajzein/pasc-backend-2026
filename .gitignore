########################################
# Server (.gitignore) - Node/TypeScript API
########################################

# Dependencies
/node_modules

# Build output
/dist
/build

# Coverage
/coverage
/.nyc_output

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment variables (keep secrets out of git)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# OS / editor junk
.DS_Store
Thumbs.db
*.swp
*.swo

# TypeScript
*.tsbuildinfo

